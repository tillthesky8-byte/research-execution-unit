{
  "Paths": {
    "Source": "data/raw/csv",
    "OutputRoot": "output",
    "ConfigurationFiles": "configs"
  },

  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft": "Warning",
      "System": "Warning"
    }
  },

  "ConnectionStrings": {
    "MarketData": "Data Source=data/raw/sqlite/market_data.db"
  },

  "Pipeline": {
    "Loader": "Sqlite",
    "Fuser": "LastObservationCarriedForward",
    "Writer": "JsonFile"
  },

  "Simulation": {
    "InitialCash": 100000,
    "ComissionModel": "Default",
    "SlippageModel": "Default"
  },

  "Output": {
    "IncludeMarketFrame": true,
    "IncludeTradeLog": true,
    "IncludeEquityCurve": true
  }
    
}
