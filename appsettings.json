{
  "ConnectionStrings": {
    "Sqlite": "Data Source=data/raw/sqlite/market_data.db"
  },

  "Paths": {
    "SourceFilePath": "data/raw/csv",
    "OutputRoot": "output",
    "ConfigurationRoot": "configs"
  },

  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft": "Warning",
      "System": "Warning"
    }
  },

  "Pipeline": {
    "Loader": "Sqlite",
    "Fuser": "LastObservationCarriedForward",
    "Writer": "JsonFile"
  },

  "Simulation": {
    "InitialCash": 100000,
    "ComissionModel": "Default",
    "SlippageModel": "Default"
  },

  "Writer": {
    "IncludeOhlcvFrames": true,
    "IncludeTradeLog": true,
    "IncludeEquityCurve": true,
    "Manager": "Default",
    "Indexer": "Default"
  }
    
}
